# Read/write token for the Vercel Blob store used to persist student
# photos. Not needed for local dev (photos fall back to apps/web/public/uploads).
# Required in production — Vercel injects this automatically once a Blob
# store is created and linked to the project.
BLOB_READ_WRITE_TOKEN=""

# Shared admin password gating everything except /apply, /edit/{token}, and
# /login. Single-instructor app — no per-user accounts.
ADMIN_PASSWORD=""

# Secret used to HMAC-sign the admin session cookie. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=""
