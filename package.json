{
  "name": "yogapratishthan",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @yogapratishthan/web dev",
    "build": "pnpm --filter @yogapratishthan/db generate && pnpm --filter @yogapratishthan/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @yogapratishthan/db generate",
    "db:push": "pnpm --filter @yogapratishthan/db push",
    "db:migrate": "pnpm --filter @yogapratishthan/db migrate",
    "db:seed": "pnpm --filter @yogapratishthan/db seed",
    "db:studio": "pnpm --filter @yogapratishthan/db studio"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@prisma/client",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "electron"
    ]
  }
}
